# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (with pgvector extension required)
DATABASE_URL="postgresql://hermes:hermes@localhost:5432/hermesos"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Required when running behind a reverse proxy or on a non-localhost domain.
# Must be the canonical public URL of your deployment (no trailing slash).
# AUTH_URL="https://yourdomain.com"

# ── OAuth Providers ───────────────────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── VPS Control Plane ─────────────────────────────────────────────────────────
# Set SENTINEL_DEFAULT_UI=true when Sentinel is the primary UI at the VPS root.
SENTINEL_DEFAULT_UI=true

# Agent endpoints (internal Docker network addresses)
HERMES_ENDPOINT=http://127.0.0.1:4860
HERMES_CLINT_ENDPOINT=http://127.0.0.1:4861
OPENCLAW_ENDPOINT=http://127.0.0.1:3000

# Directory containing per-agent config files (CLAUDE.md, config.json, etc.)
AGENT_CONFIG_DIR=/opt/sentinel-os/agents

# Model overrides (optional — defaults are set in agentRegistry.ts)
# HERMES_LISA_MODEL=claude-sonnet-4-6
# HERMES_CLINT_MODEL=claude-sonnet-4-6
# OPENCLAW_MODEL=claude-opus-4-8

# ── AI Providers (per-user, set in Settings → API Keys) ───────────────────────
# These are entered by each user in the UI and stored in their browser.
# Do NOT set them here — they are not read from the server environment.
# ANTHROPIC_API_KEY=   ← not used
# OPENAI_API_KEY=      ← not used
# OPENROUTER_API_KEY=  ← not used
